# ─────────────────────────────────────────────────
# context-forge — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# PostgreSQL password (choose a strong password)
POSTGRES_PASSWORD=changeme_strong_password

# ─── Embeddings ───────────────────────────────────
# Provider: openai | jina | openai-compatible | local
#
# openai (default):
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIMS=1536
# Requires OPENAI_API_KEY. Cost: ~$0.02 / 1M tokens (basically free).
#
# Jina AI (1M tokens/month FREE — get key at https://jina.ai):
# EMBEDDINGS_PROVIDER=jina
# EMBEDDINGS_MODEL=jina-embeddings-v3
# EMBEDDINGS_DIMS=1024
# EMBEDDINGS_API_KEY=jina_...
#
# Any OpenAI-compatible endpoint (Together AI, Voyage, etc.):
# EMBEDDINGS_PROVIDER=openai-compatible
# EMBEDDINGS_BASE_URL=https://api.together.xyz/v1
# EMBEDDINGS_MODEL=togethercomputer/m2-bert-80M-8k-retrieval
# EMBEDDINGS_DIMS=768
# EMBEDDINGS_API_KEY=your_key_here
#
# Local (no API key, runs on your machine — requires EMBEDDINGS_PROVIDER=local at build time):
# EMBEDDINGS_PROVIDER=local
# EMBEDDINGS_MODEL=all-MiniLM-L6-v2
# EMBEDDINGS_DIMS=384

# ─── LLM (for Mem0 memory extraction) ─────────────
# Provider: openai | anthropic | deepseek
# deepseek is fast and cheap — recommended if you have a key
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# DeepSeek example:
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat

# ─── API Keys ─────────────────────────────────────
OPENAI_API_KEY=sk-...

# Anthropic (optional, if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek (optional, if LLM_PROVIDER=deepseek — fast and very cheap)
# DEEPSEEK_API_KEY=sk-...

# ─── Git Remote Repos ─────────────────────────────
# GitHub personal access token (repo scope)
GITHUB_TOKEN=

# GitLab token (read_repository scope)
# For a single GitLab instance:
GITLAB_TOKEN=

# For multiple GitLab instances, use per-repo tokens in context-forge.yml

# ─── UI ───────────────────────────────────────────
# URL of the API, as seen from the browser
VITE_API_URL=http://localhost:8000

# ─── Logging ──────────────────────────────────────
LOG_LEVEL=INFO
