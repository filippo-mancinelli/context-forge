# ─────────────────────────────────────────────────
# context-forge — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# PostgreSQL password (choose a strong password)
POSTGRES_PASSWORD=changeme_strong_password

# ─── Embeddings ───────────────────────────────────
# Provider: openai | local
# - openai: requires OPENAI_API_KEY, uses text-embedding-3-small by default
# - local: uses sentence-transformers (no API key needed, runs offline)
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIMS=1536

# If using local embeddings, set:
# EMBEDDINGS_PROVIDER=local
# EMBEDDINGS_MODEL=all-MiniLM-L6-v2
# EMBEDDINGS_DIMS=384

# ─── LLM (for Mem0 memory extraction) ─────────────
# Provider: openai | anthropic | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# ─── API Keys ─────────────────────────────────────
OPENAI_API_KEY=sk-...

# Anthropic (optional, if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Git Remote Repos ─────────────────────────────
# GitHub personal access token (repo scope)
GITHUB_TOKEN=

# GitLab token (read_repository scope)
# For a single GitLab instance:
GITLAB_TOKEN=

# For multiple GitLab instances, use per-repo tokens in context-forge.yml

# ─── UI ───────────────────────────────────────────
# URL of the API, as seen from the browser
VITE_API_URL=http://localhost:8000

# ─── Logging ──────────────────────────────────────
LOG_LEVEL=INFO
